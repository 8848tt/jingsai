# 复制到仓库根目录为 .env 后执行 deploy/deploy.ps1 或 deploy/deploy.sh

# 浏览器访问地址（须与 WEB_PORT 一致，用于 CSRF / Cookie）
PUBLIC_ORIGIN=http://localhost:8080

# 对外端口（映射到 Nginx 80）
WEB_PORT=8080

# Django
DJANGO_SECRET_KEY=please-change-this-to-a-long-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api,web

# PostgreSQL（Compose 内置，一般无需改）
POSTGRES_DB=competition
POSTGRES_USER=competition
POSTGRES_PASSWORD=competition

# 可选：HTTPS 反代时开启
# DJANGO_SESSION_COOKIE_SECURE=true
# DJANGO_CSRF_COOKIE_SECURE=true
